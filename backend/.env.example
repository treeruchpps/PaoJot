# ===========================================================================
# Backend environment variables (copy to .env for local, set on Render for prod)
# ===========================================================================

# ---- Database ----
# LOCAL: Postgres ในเครื่อง (ไม่มี SSL)
# PROD:  Supabase Session pooler (IPv4) — Supabase > Connect > Session pooler
#        DB_HOST = aws-0-<region>.pooler.supabase.com
#        DB_USER = postgres.<project-ref>
#        DB_NAME = postgres
#        DB_SSLMODE = require
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=paomoney
DB_SSLMODE=disable

# ---- Server ----
# LOCAL: 8080 ก็พอ | PROD(Render): Render ใส่ PORT ให้เอง ไม่ต้องตั้ง
SERVER_PORT=8080
# GIN_MODE=release   # ตั้งเป็น env จริงบน Render (อย่าใส่ผ่าน .env เพราะ gin อ่านตอน start)

# ---- Auth (JWT) ----
# PROD: ต้องเปลี่ยนเป็นค่าสุ่มยาว ๆ ห้ามใช้ "secret" (สร้างด้วย: openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=168h

# ---- Google OAuth (backend จัดการเอง) ----
# จาก Google Cloud Console > Credentials > OAuth 2.0 Client
# PROD: GOOGLE_REDIRECT_URL = https://<your-backend>.onrender.com/api/v1/auth/google/callback
#       และเพิ่ม URL นี้ใน Authorized redirect URIs ของ Google Console ด้วย
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ---- CORS ----
# คั่นหลาย origin ด้วย comma; ถ้าเว้นว่างจะใช้ FRONTEND_URL
# PROD: https://<your-app>.vercel.app
CORS_ALLOWED_ORIGINS=
FRONTEND_URL=http://localhost:3000

# ---- LLM: Gemini (สรุปการเงิน) ----
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# ---- LLM: Typhoon (OCR สแกนใบเสร็จ) ----
TYPHOON_API_KEY=
TYPHOON_BASE_URL=https://api.opentyphoon.ai/v1
TYPHOON_EXTRACT_MODEL=typhoon-v2.5-30b-a3b-instruct

# ---- File storage: Cloudflare R2 (ไม่ตั้ง = เก็บไฟล์ลง local; บน cloud จะหายเมื่อ redeploy) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=
R2_PUBLIC_URL=
