# ===========================================================================
# PaoJot — root .gitignore
# ===========================================================================

# ---- secrets / env (commit เฉพาะไฟล์ *.env.example เท่านั้น) ----
.env
.env.local
.env.*.local
*.env
!*.env.example

# ---- backend (Go) ----
# backend/server = ไบนารีจาก go build, uploads/ = ไฟล์สลิป local fallback
backend/server
backend/uploads/
backend/tmp/
*.exe
*.test
*.out

# ---- frontend (React / CRA) ----
frontend/node_modules/
frontend/build/
frontend/.vercel/
frontend/coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- editor / OS ----
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
*.log

DEPLOY.md